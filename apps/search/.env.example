PORT=8910
HOST=0.0.0.0

# Optional bearer token for Worker -> search service internal endpoints.
SEARCH_CONTROL_TOKEN=

# Local storage paths
SEARCH_INDEX_DIR=/var/lib/diffkit-search
SEARCH_INDEX_PATH=/var/lib/diffkit-search/livegrep.idx
SEARCH_REPO_DIR=/var/lib/diffkit-search/repos
SEARCH_MANIFEST_PREFIX=search/manifests/

# Livegrep upstream (this service proxies /api/v1/search to this URL)
LIVEGREP_BASE_URL=http://127.0.0.1:8911
LIVEGREP_SEARCH_PATH=/api/v1/search
LIVEGREP_API_TOKEN=

# Policy
ALLOWED_REPO_PROVIDERS=github
MAX_REPO_SIZE_MB=10000
